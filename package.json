{
  "name": "voice-agent-realtime",
  "version": "2.0.0",
  "description": "A real-time AI voice agent — answers phone calls (Twilio) and web calls (WebRTC), holds natural spoken conversation via the OpenAI Realtime API, and takes messages with function-calling.",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test test/**/*.test.ts"
  },
  "keywords": [
    "voice-agent",
    "twilio",
    "webrtc",
    "openai-realtime",
    "ai-receptionist",
    "function-calling",
    "websocket",
    "speech-to-speech"
  ],
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "@fastify/websocket": "^10.0.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/ws": "^8.5.12",
    "tsx": "^4.16.5",
    "typescript": "^5.5.4"
  }
}
